{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "atelier",
  "version": "0.1.0",
  "identifier": "atelier.local.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "atelier",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.ico"
    ],
    "targets": "all",
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
